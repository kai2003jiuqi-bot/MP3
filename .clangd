CompileFlags:
  Add:
    - -isystemD:\Programs\Keil_v5\ARM\ARMCC\include
    - -isystemD:\Programs\Keil_v5\ARM\ARMCC\include\rw
    - -ferror-limit=0
  Remove:
    - --cpu
    - --li
    - --c99
    - --split_sections
    - --diag_suppress=*
    - --no_depend_system_headers
    - --depend
    - --strict
    - --enum_is_int
    - --gnu
    - --apcs=*
    - --signed_chars
    - --split_ldm
    - --execute_only
    - -Otime
  CompilationDatabase: ./build/project
Diagnostics:
  Suppress: "*"
